{
  "name": "cronyclaw-desktop",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/trandangtrungduc/CronyClaw.git"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,json}\" \"*.{json,yml,yaml,md}\" \"electron*.ts\" \"vite.config.ts\"",
    "lint": "eslint . --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "node -e \"const { spawnSync } = require('child_process'); const env={...process.env}; delete env.NODE_OPTIONS; const res=spawnSync('npx',['vitest','run'],{stdio:'inherit',env,shell:true}); process.exit(res.status===null?1:res.status);\"",
    "test:clean": "npm run test",
    "test:silent": "node -e \"const { spawnSync } = require('child_process'); const env={...process.env}; delete env.NODE_OPTIONS; const res=spawnSync('npx',['vitest','run','--silent'],{stdio:'inherit',env,shell:true}); process.exit(res.status===null?1:res.status);\"",
    "test:clean:silent": "npm run test:silent",
    "test:watch": "node -e \"const { spawnSync } = require('child_process'); const env={...process.env}; delete env.NODE_OPTIONS; const res=spawnSync('npx',['vitest'],{stdio:'inherit',env,shell:true}); process.exit(res.status===null?1:res.status);\"",
    "test:coverage": "node -e \"const { spawnSync } = require('child_process'); const env={...process.env}; delete env.NODE_OPTIONS; const res=spawnSync('npx',['vitest','run','--coverage'],{stdio:'inherit',env,shell:true}); process.exit(res.status===null?1:res.status);\"",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win --publish never",
    "build:mac": "electron-vite build && electron-builder --mac --publish never",
    "build:linux": "electron-vite build && electron-builder --linux --publish never",
    "dev:web": "vite serve src/renderer --config vite.config.ts",
    "build:web": "vite build --config vite.config.ts --mode web",
    "extract-translations": "i18next-scanner --config i18next-scanner.config.js"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.2.3",
    "@chatscope/chat-ui-kit-react": "^2.0.3",
    "@chatscope/chat-ui-kit-styles": "^1.4.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@emotion/react": "^11.14.0",
    "@ricky0123/vad-web": "^0.0.24",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.1.7",
    "eslint": "^9.7.0",
    "framer-motion": "^11.14.4",
    "i18next": "^25.0.1",
    "i18next-browser-languagedetector": "^8.0.5",
    "i18next-scanner": "^4.6.0",
    "next-themes": "^0.4.4",
    "onnxruntime-web": "1.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.5.1",
    "react-icons": "^5.4.0",
    "rxjs": "^7.8.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.2",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint-plugin-react": "^7.22.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.3.2",
    "typescript": "~5.8.3",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^4.0.0",
    "vitest": "^4.1.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.1"
  }
}
